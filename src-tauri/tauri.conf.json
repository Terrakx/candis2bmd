{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Candis2BMD",
  "version": "1.0.0",
  "identifier": "at.candis2bmd.import",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Candis2BMD - ER-Import Konverter",
        "width": 1000,
        "height": 950
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
